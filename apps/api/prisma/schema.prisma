model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  documents Document[]
  createdAt DateTime @default(now())
}

model Document {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  status      String
  uploadedBy  User?    @relation(fields: [uploadedById], references: [id])
  uploadedById String?
  createdAt   DateTime @default(now())
}